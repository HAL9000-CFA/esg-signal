# Cache config
USE_CACHED=true
CACHE_DIR=data/cache/
AUDIT_LOG_PATH=data/audit_log.jsonl

# Anthropic : https://console.anthropic.com/
ANTHROPIC_API_KEY=...

# Google (Gemini + Earth Engine) : https://aistudio.google.com/
GOOGLE_API_KEY=...

# Companies House : https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY=...

# EDGAR - any valid email
SEC_EMAIL=...

# SerpAPI - Google Jobs for Talent Signal (250 free searches/month, email and mobile number verification required)
# https://serpapi.com
SERPAPI_KEY=...

# SASB Navigator API - public endpoint, no auth required.
# The default URL below is the public AWS API Gateway used by the IFRS/SASB Navigator
# web frontend. Override only if the endpoint changes.
# Used by pipeline/fetchers/sasb_topics.py
SASB_API_BASE=https://owaeaasu09.execute-api.us-west-2.amazonaws.com/prod

# Airflow metadata DB
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow
AIRFLOW__CORE__FERNET_KEY=... # generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# Airflow webserver connection (used by Streamlit UI to trigger DAGs and poll results)
# Defaults below work for the local Docker Compose setup. Override for remote Airflow.
AIRFLOW_URL=http://localhost:8080
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=admin
