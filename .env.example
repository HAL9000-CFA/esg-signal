
# Anthropic : https://console.anthropic.com/
ANTHROPIC_API_KEY=...

# Google (Gemini + Earth Engine) : https://aistudio.google.com/
GOOGLE_API_KEY=...

# Companies House : https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY=...

# GDELT — base url documented, no key needed
GDELT_BASE_URL=https://api.gdeltproject.org/api/v2

# Airflow metadata DB
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow
AIRFLOW__CORE__FERNET_KEY=  # generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

